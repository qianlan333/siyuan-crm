AICRM_NEXT_WECHAT_PAY_MODE=
AICRM_NEXT_WECOM_DISPATCH_MODE=
AICRM_NEXT_WECOM_MEDIA_MODE=
AICRM_NEXT_WECOM_REAL_CALLS_ENABLED=
AICRM_NEXT_WECOM_TAG_MODE=
AICRM_NEXT_ACTION_TOKEN_SECRET=

# ================ 自动化转化 / SOP / worker ================
