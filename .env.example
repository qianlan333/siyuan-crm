# ================ 群运营/素材/标签适配器 ================
AICRM_GROUP_OPS_MATERIAL_UPLOAD_MODE=
AICRM_GROUP_OPS_PRIVATE_MESSAGE_MODE=
AICRM_GROUP_OPS_TIMEZONE=Asia/Shanghai
