# siyuan-crm 环境变量模板
# 部署建议: /home/ubuntu/.openclaw-wecom-pg.env, 权限 600, 不入仓库
# 当前代码基线: AI-CRM Next; 数据和授权配置按 siyuan 生产 overlay 保留
# 请勿在本文件写入真实 AccessToken、Secret、AESKey、AppSecret、私钥内容或生产密码。

# ================ 生产必填: 应用基础 ================
APP_ENV=production
APP_HOST=127.0.0.1
APP_PORT=5001
DEPLOY_ENV=production
FLASK_ENV=production
SECRET_KEY=                         # 生产必填: Flask/FastAPI session/action token 相关密钥, 随机 64 位字符串
RELEASE_SHA=                        # 可选: 部署时填 git commit sha
AICRM_NEXT_RELEASE_SHA=             # 可选: Next 响应头展示的 release sha
AICRM_NEXT_ENV=production
AICRM_ADMIN_BRAND_NAME=心流商业客户管理
ADMIN_BRAND_NAME=心流商业客户管理

# ================ 生产必填: 数据库 ================
DATABASE_URL=postgresql+psycopg://openclaw:CHANGEME@127.0.0.1:5432/openclaw
DATABASE_PATH=                      # 旧 SQLite 兼容字段, PG 模式留空
SQLITE_BUSY_TIMEOUT_MS=             # SQLite 用, PG 留空
DB_APPLICATION_NAME=siyuan-crm-next

# ================ 可选: 第二库/缓存 ================
MESSAGE_ACTIVITY_DB_HOST=
MESSAGE_ACTIVITY_DB_PORT=
MESSAGE_ACTIVITY_DB_NAME=
MESSAGE_ACTIVITY_DB_USER=
MESSAGE_ACTIVITY_DB_PASS=
REDIS_URL=

# ================ 生产必填: 后台管理登录 ================
ADMIN_AUTH_MODE=wecom_sso
ADMIN_LOGIN_REDIRECT_URI=https://www.xinliushangye.com/auth/wecom/callback
ADMIN_WECHAT_TRUSTED_DOMAIN=www.xinliushangye.com
AICRM_NEXT_WECOM_ADMIN_AUTH_MODE=blocked   # blocked/live; 生产切换启用企微 SSO 前必须显式设为 live
AICRM_NEXT_WECOM_ADMIN_AUTH_TIMEOUT_SECONDS=10
AICRM_NEXT_ADMIN_SESSION_COOKIE_SECURE=     # 留空时按请求 scheme/生产环境判断; 本地测试可设 false
ADMIN_BREAK_GLASS_LOGIN_ENABLED=    # true/false; 仅应急时开启
ADMIN_BREAK_GLASS_USERNAME=
ADMIN_BREAK_GLASS_PASSWORD_HASH=    # bcrypt 哈希, 不要填写明文密码

# ================ 生产必填: 企业微信 ================
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_SECRET=
WECOM_CONTACT_SECRET=
WECOM_CALLBACK_TOKEN=
WECOM_CALLBACK_AES_KEY=
WECOM_API_BASE=https://qyapi.weixin.qq.com
WECOM_DEFAULT_OWNER_USERID=
WECOM_PRIVATE_KEY_PATH=             # 可选: 会话存档解密私钥文件路径, 文件不入仓库
WECOM_ARCHIVE_SECRET=
WECOM_ARCHIVE_TIMEOUT=
WECOM_SYNC_BATCH_SIZE=
WECOM_SYNC_RETRY_LIMIT=
WECOM_TIMEOUT_SECONDS=
WECOM_CORP_TAG_LIMIT=
ACCESS_TOKEN_CACHE_SECONDS=

# ================ 生产必填: 微信公众号/OAuth ================
WECHAT_MP_APP_ID=
WECHAT_MP_APPID=                    # 兼容别名, 如代码/旧配置使用
WECHAT_MP_APP_SECRET=
WECHAT_MP_OAUTH_SCOPE=snsapi_userinfo
WECHAT_OAUTH_APPID=
WECHAT_OAUTH_TIMEOUT=

# ================ 可选: 微信支付/支付宝 ================
WECHAT_PAY_ENABLED=false
WECHAT_PAY_APP_ID=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_PRIVATE_KEY_PATH=
WECHAT_PAY_CERT_SERIAL_NO=
WECHAT_PAY_PLATFORM_PUBLIC_KEY_PATH=
WECHAT_PAY_PLATFORM_CERT_SERIAL_NO=
WECHAT_PAY_NOTIFY_URL=
WECHAT_PAY_API_BASE=https://api.mch.weixin.qq.com
WECHAT_PAY_TIMEOUT_SECONDS=10
WECHAT_PAY_PRODUCT_CATALOG_JSON=
ALIPAY_ENABLED=false
ALIPAY_APP_ID=
ALIPAY_APP_PRIVATE_KEY_PATH=
ALIPAY_PUBLIC_KEY_PATH=
ALIPAY_SERVER_URL=https://openapi.alipay.com/gateway.do
ALIPAY_SIGN_TYPE=RSA2
ALIPAY_NOTIFY_URL=
ALIPAY_RETURN_URL=
ALIPAY_TIMEOUT_EXPRESS=30m
ALIPAY_TIMEOUT_SECONDS=10
ALIPAY_SELLER_ID=

# ================ 可选: 飞书 ================
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_BOT_NAME=
FEISHU_API_BASE=https://open.feishu.cn
FEISHU_REQUEST_TIMEOUT_SECONDS=

# ================ 生产必填/可选: CRM API / MCP / 侧边栏 ================
CRM_API_BASE_URL=
CRM_API_TOKEN=                      # 如启用外部 CRM API, 生产必填
CRM_API_TIMEOUT_MS=
CRM_API_MAX_RETRIES=
CRM_API_RETRY_BACKOFF_SECONDS=
CRM_PREFER_CUSTOMER_ENDPOINTS=
CRM_PREFER_TIMELINE_ENDPOINT=
CRM_MCP_BEARER_TOKEN=
MCP_BEARER_TOKEN=                   # 如启用 MCP/internal API, 生产必填
SIDEBAR_THIRD_PARTY_API_URL=
SIDEBAR_THIRD_PARTY_API_TOKEN=      # 如启用第三方侧边栏接口, 生产必填
SIDEBAR_THIRD_PARTY_TIMEOUT_SECONDS=
SIDEBAR_WORKBENCH_V2_ENABLED=true
SIDEBAR_PERSON_DETAIL_URL_TEMPLATE=

# ================ AI-CRM Next 模式开关 ================
AICRM_NEXT_ALLOW_FIXTURE_REPO_IN_PROD=false
AICRM_NEXT_DISABLE_LEGACY_PRODUCTION_FACADE=
AICRM_NEXT_ENABLE_LEGACY_PRODUCTION_FACADE=
AICRM_NEXT_ENABLE_PRODUCTION_PROBE_DRY_RUN=
AICRM_NEXT_CONTACTS_SYNC_MODE=
AICRM_NEXT_CUSTOMER_PROJECTION_SYNC_MODE=
AICRM_NEXT_IDENTITY_MAPPING_MODE=
AICRM_NEXT_MCP_TOOL_MODE=
AICRM_NEXT_MEDIA_STORAGE_MODE=
AICRM_NEXT_OPENCLAW_LEGACY_MODE=
AICRM_NEXT_OPENCLAW_WEBHOOK_MODE=
AICRM_NEXT_PAYMENT_NOTIFY_MODE=
AICRM_NEXT_PRODUCT_WRITE_MODE=
AICRM_NEXT_QUESTIONNAIRE_WEBHOOK_MODE=
AICRM_NEXT_USER_OPS_BATCH_SEND_MODE=
