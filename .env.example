# siyuan-crm 环境变量模板
# 部署到 /home/ubuntu/.openclaw-wecom-pg.env(权限 600,不入仓库)
# 字段来源:扫描代码中 os.getenv(...) 调用得到

# ================ 应用基础 ================
APP_ENV=production
APP_HOST=127.0.0.1
APP_PORT=5001
DEPLOY_ENV=production
FLASK_ENV=production
SECRET_KEY=                         # Flask session 密钥,随机 64 位字符串
RELEASE_SHA=                        # 可选,部署时填 git commit sha

# ================ 数据库 ================
DATABASE_URL=postgresql+psycopg://openclaw:CHANGEME@127.0.0.1:5432/openclaw
DATABASE_PATH=                      # 旧 SQLite 兼容字段,PG 模式留空
SQLITE_BUSY_TIMEOUT_MS=             # SQLite 用,PG 留空

# 第二库(消息活动,如使用 MySQL)
MESSAGE_ACTIVITY_DB_HOST=
MESSAGE_ACTIVITY_DB_PORT=
MESSAGE_ACTIVITY_DB_NAME=
MESSAGE_ACTIVITY_DB_USER=
MESSAGE_ACTIVITY_DB_PASS=

# 缓存(可选)
REDIS_URL=

# ================ 后台管理登录 ================
ADMIN_AUTH_MODE=                    # 例如 wechat / break_glass
ADMIN_LOGIN_REDIRECT_URI=https://www.xinliushangye.com/admin
ADMIN_WECHAT_TRUSTED_DOMAIN=www.xinliushangye.com
ADMIN_BREAK_GLASS_LOGIN_ENABLED=    # true/false
ADMIN_BREAK_GLASS_USERNAME=
ADMIN_BREAK_GLASS_PASSWORD_HASH=    # bcrypt 哈希

# ================ 企业微信 ================
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_SECRET=
WECOM_CONTACT_SECRET=
WECOM_CALLBACK_TOKEN=
WECOM_CALLBACK_AES_KEY=
WECOM_API_BASE=https://qyapi.weixin.qq.com
WECOM_DEFAULT_OWNER_USERID=
WECOM_PRIVATE_KEY_PATH=             # 会话存档解密私钥文件路径(可选)
WECOM_ARCHIVE_SECRET=
WECOM_ARCHIVE_TIMEOUT=
WECOM_SYNC_BATCH_SIZE=
WECOM_SYNC_RETRY_LIMIT=
ACCESS_TOKEN_CACHE_SECONDS=

# ================ 微信公众号 ================
WECHAT_MP_APP_ID=
WECHAT_MP_APP_SECRET=
WECHAT_MP_OAUTH_SCOPE=snsapi_userinfo

# ================ 飞书 ================
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_BOT_NAME=
FEISHU_API_BASE=https://open.feishu.cn
FEISHU_REQUEST_TIMEOUT_SECONDS=

# ================ CRM API / MCP ================
CRM_API_BASE_URL=
CRM_API_TOKEN=
CRM_API_TIMEOUT_MS=
CRM_API_MAX_RETRIES=
CRM_API_RETRY_BACKOFF_SECONDS=
CRM_PREFER_CUSTOMER_ENDPOINTS=
CRM_PREFER_TIMELINE_ENDPOINT=
CRM_MCP_BEARER_TOKEN=
MCP_BEARER_TOKEN=

# ================ 自动化转化 / SOP ================
AUTOMATION_CONVERSION_CHANNEL_PROVIDER=
AUTOMATION_CONVERSION_DUE_JOBS=
AUTOMATION_CONVERSION_DUE_OPERATOR=
AUTOMATION_CONVERSION_DUE_RETRY_COUNT=
AUTOMATION_CONVERSION_DUE_RETRY_INTERVAL_SECONDS=
AUTOMATION_INTERNAL_API_TOKEN=
AUTOMATION_SOP_OPERATOR=
AUTOMATION_SOP_RETRY_COUNT=
AUTOMATION_SOP_RETRY_INTERVAL_SECONDS=
AUTOMATION_SOP_RUNNER_PATH=

# ================ 老黄/客服群通道(可选) ================
LAOHUANG_CHAT_ENABLED=
LAOHUANG_CHAT_SEND_CHANNEL=
LAOHUANG_CHAT_TIMEOUT_SECONDS=
LAOHUANG_CHAT_WEBHOOK_URL=

# ================ 侧边栏第三方对接(可选) ================
SIDEBAR_THIRD_PARTY_API_URL=
SIDEBAR_THIRD_PARTY_API_TOKEN=
SIDEBAR_THIRD_PARTY_TIMEOUT_SECONDS=

# ================ 其他 ================
OPENCLAW_WEBHOOK_URL=
ENABLE_DEBUG_QUESTIONNAIRE_SESSION_API=
ENV_FILE_PATH=
