# Example nginx snippet for routing WeCom callbacks to the isolated AI-CRM
# callback ingress runtime on 127.0.0.1:5002.
#
# This is a deployment template only. Do not paste it blindly over the
# production server block; merge it into /etc/nginx/sites-enabled/youcangogogo.conf
# during a controlled cutover.
#
# Add the shared zones below at nginx http{} scope, not inside server{}.
limit_req_zone $binary_remote_addr zone=aicrm_wecom_callback_req:10m rate=30r/s;
limit_conn_zone $binary_remote_addr zone=aicrm_wecom_callback_conn:10m;

upstream aicrm_web {
    server 127.0.0.1:5001;
    keepalive 32;
}

upstream aicrm_wecom_ingress {
    server 127.0.0.1:5002;
    keepalive 16;
}

location / {
    proxy_pass http://aicrm_web;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
}

location = /wecom/external-contact/callback {
    client_max_body_size 1m;
    limit_req zone=aicrm_wecom_callback_req burst=120 nodelay;
    limit_conn aicrm_wecom_callback_conn 20;
    limit_req_status 429;
    limit_conn_status 429;
    proxy_pass http://aicrm_wecom_ingress;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_connect_timeout 1s;
    proxy_send_timeout 3s;
    proxy_read_timeout 3s;
    proxy_buffering off;
}

location = /api/wecom/events {
    client_max_body_size 1m;
    limit_req zone=aicrm_wecom_callback_req burst=120 nodelay;
    limit_conn aicrm_wecom_callback_conn 20;
    limit_req_status 429;
    limit_conn_status 429;
    proxy_pass http://aicrm_wecom_ingress;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_connect_timeout 1s;
    proxy_send_timeout 3s;
    proxy_read_timeout 3s;
    proxy_buffering off;
}
