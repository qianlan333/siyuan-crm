[Unit]
Description=OpenClaw Broadcast Queue Worker — dispatch due broadcast_jobs
After=network.target openclaw-wecom-postgres.service
Requires=openclaw-wecom-postgres.service

[Service]
Type=oneshot
User=ubuntu
WorkingDirectory=/home/ubuntu/极简 crm
EnvironmentFile=/home/ubuntu/.openclaw-wecom-pg.env
Environment=AICRM_GROUP_OPS_MATERIAL_UPLOAD_MODE=real
ExecStart=/bin/bash -lc 'source /home/ubuntu/venvs/openclaw/bin/activate && python scripts/run_broadcast_queue_worker.py'
